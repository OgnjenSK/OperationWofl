{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start local server",
      "type": "shell",
      "command": "bash scripts/start-server.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      }
    },
    {
      "label": "Play Game in Browser",
      "dependsOn": ["Start local server"],
      "dependsOrder": "sequence",
      "type": "shell",
      "command": "open 'http://127.0.0.1:8080/index.html'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      }
    },
    {
      "label": "Stop local server",
      "type": "shell",
      "command": "if [ -f .vscode/dev-server.pid ]; then kill \"$(cat .vscode/dev-server.pid)\" 2>/dev/null || true; rm -f .vscode/dev-server.pid; fi",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
