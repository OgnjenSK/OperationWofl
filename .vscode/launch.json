{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch Game (localhost:8080)",
      "url": "http://127.0.0.1:8080/Operation%20Wofl.html",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "Start local server"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Play Game (browser only)",
      "url": "http://127.0.0.1:8080/Operation%20Wofl.html",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "Start local server",
      "runtimeArgs": ["--new-window"]
    }
  ]
}
